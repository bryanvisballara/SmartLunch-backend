{
  "name": "comergio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generateStaticRouteFallbacks.mjs",
    "mobile:build": "npm run build && npm run cap:sync",
    "mobile:build:remote": "npm run build && npm run cap:sync",
    "mobile:build:embedded": "CAPACITOR_USE_EMBEDDED=true npm run build && CAPACITOR_USE_EMBEDDED=true npm run cap:sync",
    "cap:sync": "node scripts/runCapSync.mjs",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.1.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/app-launcher": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@simplewebauthn/browser": "^13.2.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "firebase": "^12.11.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "react-select": "^5.8.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
