# Mobile shell (Capacitor) — Option A: load UI from Hostinger/production web
#
# Copy to `.env.mobile` to override locally, or set CAPACITOR_SERVER_URL in `.env.production`.
#
# Remote shell (default): app iOS/Android opens this URL; deploys to Hostinger update the app instantly.
CAPACITOR_SERVER_URL=https://comergio.com
#
# Embedded shell: bundle dist inside the .ipa/.apk (needs App Store for UI changes).
# CAPACITOR_USE_EMBEDDED=true
