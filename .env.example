NODE_ENV=development
PORT=4000
MONGO_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=comergio
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,https://comergio.com,https://www.comergio.com
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+\.hostingersite\.com$
REDIS_URL=redis://localhost:6379
NOTIFICATION_WORKER_CONCURRENCY=10
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Comergio
UPLOADS_ROOT_PATH=/home/your-user/public_html/assets
UPLOADS_PUBLIC_BASE_URL=https://floralwhite-albatross-668675.hostingersite.com/assets
UPLOADS_MAX_WIDTH_PX=600
UPLOADS_WEBP_QUALITY=78
UPLOADS_THUMB_MAX_WIDTH_PX=250
UPLOADS_THUMB_WEBP_QUALITY=70
UPLOADS_MAX_FILE_BYTES=5242880
MENU_CACHE_TTL_SECONDS=120
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=comergio
FRONTEND_URL=https://comergio.com
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_WEBHOOK_SECRET=
# ePayco – https://dashboard.epayco.com → Configuración → Llaves de API
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_API_URL=https://api.epayco.co
# Optional: P_CUST_ID_CLIENTE when login must be done as cliente registrador.
EPAYCO_ENTITY_CLIENT_ID=
# Optional override; by default backend uses /token/customer from APIFY collection
EPAYCO_CUSTOMER_CREATE_PATH=/token/customer
# Optional fallback for initial tests when account only allows adding tokens to an existing customer
EPAYCO_EXISTING_CUSTOMER_ID=
# Set to "true" when using ePayco sandbox / test mode
EPAYCO_TEST=false

